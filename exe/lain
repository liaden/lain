#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "thor"

require "lain"

# The executable. Deliberately thin: parse flags, wire the real collaborators
# together, hand off to Frontend::TTY. Nothing here is unit-tested the way
# lib/ is (see CLAUDE.md), so nothing here decides anything -- Effect::Handler::Gate,
# Tool, and TTY already carry the logic and already carry the specs.
class LainCLI < Thor
  # Turns the chat flags into the two collaborators the Agent needs a CHOICE
  # about -- which Provider backend, and the Context carrying the model and the
  # sampler params (temperature/seed) that ride Request#extra. A plain object,
  # not a bag of methods on LainCLI: the provider/model resolution is then
  # unit-testable without a Thor instance. It lives in lib (Lain::CLI::Backend)
  # so `bench record` resolves providers through the identical object; the exe
  # keeps the alias and maps its Lain error to Thor's.
  Backend = Lain::CLI::Backend

  # Errors (a Thor::Error surfaced from a subcommand included) print their
  # message and exit nonzero, instead of Thor's legacy exit-0 default.
  def self.exit_on_failure? = true

  # The bench subcommands, on the same thin-wiring rule as chat: Bench::CLI
  # assembles everything and returns Strings; this class parses flags, `say`s
  # what comes back, and presents the lib's own errors -- all Lain::Error:
  # Bench::CLI::Refusal, Session::Corrupt, the ANTHROPIC_API_KEY gate -- as
  # Thor::Error, message to stderr, nonzero exit, no backtrace. Anything else
  # (a bare ArgumentError included) is a bug and keeps its backtrace.
  class Bench < Thor
    def self.exit_on_failure? = true

    desc "variance DIR_OR_FILES...", "Report determinism/divergence/distribution across recorded sessions"
    def variance(*sources)
      say Lain::Bench::CLI.new.variance_report(sources)
    rescue Lain::Error => e
      raise Thor::Error, e.message
    end

    desc "record TASKFILE", "Record N live runs of a task file (one prompt per line) -- spends real API money"
    method_option :n, type: :numeric, default: Lain::Bench::CLI::RECORD_DEFAULTS.fetch(:runs),
                      desc: "how many runs"
    method_option :out, type: :string, required: true, desc: "directory the session files land in"
    method_option :model, type: :string,
                          desc: "Model id; defaults to the selected provider's own default when unset"
    method_option :max_tokens, type: :numeric, default: Lain::Bench::CLI::RECORD_DEFAULTS.fetch(:max_tokens),
                               desc: "max_tokens per model turn"
    method_option :system, type: :string, desc: "system prompt"
    method_option :provider, type: :string, default: "anthropic",
                             desc: "Model provider: anthropic, ollama, or bedrock"
    method_option :api_base, type: :string, desc: "Override the Ollama API base (ollama provider only)"
    method_option :temperature, type: :numeric, desc: "Sampler temperature, threaded into Request#extra"
    method_option :seed, type: :numeric, desc: "Sampler seed, threaded into Request#extra"
    # Flag name → Bench::CLI#record keyword. One declarative map, so adding a
    # sampler flag is one line here and one method_option above.
    RECORD_FLAGS = { n: :runs, out: :out, model: :model, max_tokens: :max_tokens,
                     system: :system, provider: :provider_name, api_base: :api_base,
                     temperature: :temperature, seed: :seed }.freeze

    def record(taskfile)
      kwargs = RECORD_FLAGS.to_h { |flag, keyword| [keyword, options[flag]] }
      Lain::Bench::CLI.new.record(taskfile:, **kwargs).each { |path| say path }
    rescue Lain::Error => e
      raise Thor::Error, e.message
    end

    desc "sweep", "Deterministic five-arm retrieval eval (recall@k over the gold corpus) -- offline, no API"
    method_option :k, type: :numeric, default: Lain::Bench::Sweep::DEFAULT_K,
                      aliases: "-k", desc: "retrieval depth (recall@k)"
    def sweep
      say Lain::Bench::CLI.new.sweep_report(k: options[:k])
    rescue Lain::Error => e
      raise Thor::Error, e.message
    end
  end

  desc "bench SUBCOMMAND ...ARGS", "Bench drivers over recorded sessions (variance, record, sweep)"
  subcommand "bench", Bench

  desc "chat", "Start an interactive Lain session"
  method_option :yolo, type: :boolean, default: false,
                       desc: "Skip the approval prompt for tier-3 (free-form shell) tools"
  method_option :provider, type: :string, default: "anthropic",
                           desc: "Model provider: anthropic, ollama, or bedrock"
  method_option :api_base, type: :string,
                           desc: "Override the Ollama API base (ollama provider only)"
  method_option :model, type: :string,
                        desc: "Model id; defaults to the selected provider's own default when unset"
  method_option :max_tokens, type: :numeric, default: 4_096,
                             desc: "max_tokens per model turn"
  method_option :temperature, type: :numeric,
                              desc: "Sampler temperature, threaded into Request#extra (ollama honors it)"
  method_option :seed, type: :numeric,
                       desc: "Sampler seed, threaded into Request#extra (ollama honors it)"
  default_task :chat

  def chat
    channel = Lain::Channel.new
    # One Recorder backs the memory_write tool for the whole session -- the
    # single mutable holder of the live Memory::Index, so each write supersedes
    # the last (its prior root still resolves the old item).
    recorder = Lain::Memory::Recorder.new
    agent = wire_agent(channel:, recorder:)
    tty = Lain::Frontend::TTY.new(channel:)
    repl_middleware = build_repl_middleware

    repl = Repl.new(agent:, tty:, middleware: repl_middleware,
                    ask_human: @ask_human, questions: @questions)
    tty.run { repl.converse }
  rescue Lain::CLI::UnknownProvider => e
    raise Thor::Error, e.message
  end

  private

  # The repl phase: a Middleware::Stack wrapping EACH command typed at the
  # prompt, wired the same way Agent's model_/tool_/turn_middleware already
  # are (see lib/lain/agent.rb) -- reusing Middleware::Stack rather than
  # inventing a parallel mechanism. An honest pass-through by default; this is
  # the seam a future history/logging/confirmation phase lands on, not that
  # feature yet.
  def build_repl_middleware
    Lain::Middleware::Stack.new
  end

  # The subagent tool reads the live parent head at spawn time, so the Agent is
  # late-bound through a thunk: the closure captures the BINDING, and `agent` is
  # assigned after the toolset that closes over it. The SAME recorder backs the
  # session's manifest and the read/write tools -- one index, three views.
  def wire_agent(channel:, recorder:)
    backend = Backend.new(options)
    agent = nil
    parent = -> { agent.timeline }
    # The replier fiber (see #respond) parks on @questions and answers through
    # @ask_human -- exe-instance state because the reply path and the toolset
    # are wired in different methods of this one command invocation. The
    # enqueue happens inside #ask (before perform's await), and Async::Queue
    # is buffered, so the replier can never park on an already-asked question.
    @questions = Async::Queue.new
    @ask_human = Lain::Tools::AskHuman::Notifying.new(notify: @questions.method(:enqueue), parent:)
    toolset = build_toolset(recorder, backend:, parent:, journal: channel, ask_human: @ask_human)
    agent = build_agent(toolset:, channel:, session: Lain::Session.new(memory: recorder), backend:)
  end

  def build_toolset(recorder, backend:, parent:, journal:, ask_human:)
    base = Lain::Toolset.new([
                               Lain::Tools::ReadFile.new,
                               Lain::Tools::ListFiles.new,
                               Lain::Tools::EditFile.new,
                               Lain::Tools::TodoWrite.new,
                               Lain::Tools::MemoryWrite.new(recorder:),
                               Lain::Tools::MemoryRead.new(index: recorder),
                               Lain::Tools::Bash.new
                             ])
    Lain::Toolset.new(base.to_a + [research_subagent(base, backend:, parent:, journal:), ask_human])
  end

  # The chat default: an attenuated read-only child (schema posture, depth 1).
  def research_subagent(base, backend:, parent:, journal:)
    Lain::Tools::Subagent.new(
      provider: backend.provider, context_factory: -> { backend.context }, toolset: base,
      policy: Lain::Tool::SpawnPolicy.new(prefix: :fresh, posture: :schema,
                                          only: %i[read_file list_files]),
      parent:, journal:, max_depth: 1
    )
  end

  # Gate and Live share ONE Toolset (the single-map invariant the plan
  # calls out): a second Toolset reference here could let the approval gate
  # and the executor disagree about what a tool name means. RefuseSecretWrites
  # sits in the tool phase so a credential-shaped memory_write is withheld
  # before it ever reaches the recorder (a memory, once indexed, replays into
  # every future context -- there is no un-indexing it).
  # `session:` is REQUIRED, not defaulted: a defaulted fresh Session would
  # silently mis-wire memory -- a caller passing a recorder-bearing toolset
  # but forgetting session: would get working memory tools with a permanently
  # blind manifest. Forgetting must be a loud ArgumentError, not a quiet
  # degrade (T1 panel, Schneeman).
  def build_agent(toolset:, channel:, session:, backend:)
    live = Lain::Effect::Handler::Live.new(toolset:, channel:)
    gate = Lain::Effect::Handler::Gate.new(policy: approval_policy, inner: live)

    Lain::Agent.new(provider: backend.provider, toolset:, context: backend.context, handler: gate, session:,
                    tool_middleware: Lain::Middleware::Stack.new([Lain::Middleware::RefuseSecretWrites.new]))
  end

  def approval_policy
    return Lain::Effect::Handler::Gate::ApproveAll.new if options[:yolo]

    Lain::Frontend::ApprovalPolicy.new
  end

  # One conversation: reads commands at `you>`, routes each through the repl
  # phase, and hosts the two-fiber ask_human reply path. Extracted from the
  # Thor class because a conversation is its own responsibility (and the
  # Metrics trip said so -- extract, do not loosen).
  class Repl
    def initialize(agent:, tty:, middleware:, ask_human:, questions:)
      @agent = agent
      @tty = tty
      @middleware = middleware
      @ask_human = ask_human
      @questions = questions
    end

    # No next/break: the loop exit is text own truthiness, reassigned each
    # pass, the same shape the project style favors elsewhere.
    def converse
      text = @tty.prompt("you> ")
      while text && !farewell?(text)
        dispatch(text)
        text = @tty.prompt("you> ")
      end
    end

    private

    # Routes one typed command through the repl phase. `:text`/`:agent` go in;
    # the phase downstream runs the real dispatch and adds `:response` (nil on
    # a rescued Lain::Error) on the way out -- the same in/out shape
    # model_middleware uses for `:request`/`:response`.
    def dispatch(text)
      @middleware.call({ text:, agent: @agent }) do |env|
        env.merge(response: respond(env.fetch(:text)))
      end
    end

    # Two fibers: `ask` parks inside ask_human#perform awaiting the reply, and
    # the reply comes from this same terminal -- a single-fiber ask-then-prompt
    # deadlocks (OM-4 depends on OM-0). `replier.stop` in ensure is
    # load-bearing: a parked replier holds Sync open forever on the
    # no-question path.
    def respond(text)
      Sync do |task|
        replier = answer_loop(task)
        response = task.async { @agent.ask(text) }.wait
        @tty.render_response(response) if response
      ensure
        replier&.stop
      end
    rescue Lain::Error => e
      @tty.render_error(e.message)
    end

    # Parks on dequeue (a real scheduler yield -- woken per question, never
    # polling). `.to_s` is load-bearing: EOF makes prompt return nil, and an
    # empty answer is honest where Tool::Result.ok(nil) would raise.
    def answer_loop(task)
      task.async do
        loop do
          @tty.render_question(@questions.dequeue)
          @ask_human.reply(@tty.prompt("human> ").to_s)
        end
      end
    end

    def farewell?(text)
      %w[exit quit].include?(text.strip.downcase)
    end
  end
end

# Guarded so a spec can `load` this file to reach the class seam (build_agent,
# build_provider) without parsing ARGV or hitting the network. True when run as
# the gem executable ($0 is this script); false when loaded from elsewhere.
LainCLI.start(ARGV) if $PROGRAM_NAME == __FILE__
