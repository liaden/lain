#!/usr/bin/env ruby
# frozen_string_literal: true

# Ruby 4 warns "IO::Buffer is experimental" on first use (the Journal's
# fsync'd frames), straight onto the chat TTY -- interpreter noise smearing
# the frontend's screen, not an output-discipline violation. Silencing global
# Warning state is the EXE's call; the library must never do it for its host.
Warning[:experimental] = false

require "bundler/setup"
require "thor"

require "lain"

# The executable. Deliberately thin: parse flags, wire the real collaborators
# together, hand off to Frontend::TTY. Nothing here is unit-tested the way
# lib/ is (see CLAUDE.md), so nothing here decides anything -- Effect::Handler::Gate,
# Tool, and TTY already carry the logic and already carry the specs.
class LainCLI < Thor
  # Turns the chat flags into the two collaborators the Agent needs a CHOICE
  # about -- which Provider backend, and the Context carrying the model and the
  # sampler params (temperature/seed) that ride Request#extra. A plain object,
  # not a bag of methods on LainCLI: the provider/model resolution is then
  # unit-testable without a Thor instance. It lives in lib (Lain::CLI::Backend)
  # so `bench record` resolves providers through the identical object; the exe
  # keeps the alias and maps its Lain error to Thor's.
  Backend = Lain::CLI::Backend

  # Errors (a Thor::Error surfaced from a subcommand included) print their
  # message and exit nonzero, instead of Thor's legacy exit-0 default.
  def self.exit_on_failure? = true

  # Thor swallows the "--" separator before a command method sees its argv,
  # so remember whether this invocation carried one: `up` forwards trailing
  # args to the chat window ONLY after `--` -- a bare `lain up typo` must
  # stay a loud error, never silent pass-through to chat.
  def self.start(given_args = ARGV, config = {})
    @double_dash = given_args.include?("--")
    super
  end

  def self.double_dash? = !!@double_dash

  # The bench subcommands, on the same thin-wiring rule as chat: Bench::CLI
  # assembles everything and returns Strings; this class parses flags, `say`s
  # what comes back, and presents the lib's own errors -- all Lain::Error:
  # Bench::CLI::Refusal, Session::Corrupt, the ANTHROPIC_API_KEY gate -- as
  # Thor::Error, message to stderr, nonzero exit, no backtrace. Anything else
  # (a bare ArgumentError included) is a bug and keeps its backtrace.
  class Bench < Thor
    def self.exit_on_failure? = true

    desc "variance DIR_OR_FILES...", "Report determinism/divergence/distribution across recorded sessions"
    def variance(*sources)
      say Lain::Bench::CLI.new.variance_report(sources)
    rescue Lain::Error => e
      raise Thor::Error, e.message
    end

    desc "record TASKFILE", "Record N live runs of a task file (one prompt per line) -- spends real API money"
    method_option :n, type: :numeric, default: Lain::Bench::CLI::RECORD_DEFAULTS.fetch(:runs),
                      desc: "how many runs"
    method_option :out, type: :string, required: true, desc: "directory the session files land in"
    method_option :model, type: :string,
                          desc: "Model id; defaults to the selected provider's own default when unset"
    method_option :max_tokens, type: :numeric, default: Lain::Bench::CLI::RECORD_DEFAULTS.fetch(:max_tokens),
                               desc: "max_tokens per model turn"
    method_option :system, type: :string, desc: "system prompt"
    method_option :provider, type: :string, default: "anthropic",
                             desc: "Model provider: anthropic, ollama, or bedrock"
    method_option :api_base, type: :string, desc: "Override the Ollama API base (ollama provider only)"
    method_option :temperature, type: :numeric, desc: "Sampler temperature, threaded into Request#extra"
    method_option :seed, type: :numeric, desc: "Sampler seed, threaded into Request#extra"
    # Flag name → Bench::CLI#record keyword. One declarative map, so adding a
    # sampler flag is one line here and one method_option above.
    RECORD_FLAGS = { n: :runs, out: :out, model: :model, max_tokens: :max_tokens,
                     system: :system, provider: :provider_name, api_base: :api_base,
                     temperature: :temperature, seed: :seed }.freeze

    def record(taskfile)
      kwargs = RECORD_FLAGS.to_h { |flag, keyword| [keyword, options[flag]] }
      Lain::Bench::CLI.new.record(taskfile:, **kwargs).each { |path| say path }
    rescue Lain::Error => e
      raise Thor::Error, e.message
    end

    desc "plan-sweep", "Shape x density sweep over a fixture plan's scripted runs -- offline, deterministic"
    method_option :plan, type: :string, required: true, desc: "the fixture plan markdown (P1 format, seams visible)"
    method_option :runs, type: :string, required: true, desc: "the scripted runs YAML"
    def plan_sweep
      say Lain::Bench::CLI.new.plan_sweep_report(plan_path: options[:plan], runs_path: options[:runs])
    rescue Lain::Error => e
      raise Thor::Error, e.message
    end

    desc "sweep", "Deterministic five-arm retrieval eval (recall@k over the gold corpus) -- offline, no API"
    method_option :k, type: :numeric, default: Lain::Bench::Sweep::DEFAULT_K,
                      aliases: "-k", desc: "retrieval depth (recall@k)"
    def sweep
      say Lain::Bench::CLI.new.sweep_report(k: options[:k])
    rescue Lain::Error => e
      raise Thor::Error, e.message
    end
  end

  desc "bench SUBCOMMAND ...ARGS", "Bench drivers over recorded sessions (variance, record, sweep)"
  subcommand "bench", Bench

  desc "chat", "Start an interactive Lain session"
  method_option :yolo, type: :boolean, default: false,
                       desc: "Skip the approval prompt for tier-3 (free-form shell) tools"
  method_option :provider, type: :string, default: "anthropic",
                           desc: "Model provider: anthropic, ollama, or bedrock"
  method_option :api_base, type: :string,
                           desc: "Override the Ollama API base (ollama provider only)"
  method_option :model, type: :string,
                        desc: "Model id; defaults to the selected provider's own default when unset"
  method_option :max_tokens, type: :numeric, default: 4_096,
                             desc: "max_tokens per model turn"
  method_option :temperature, type: :numeric,
                              desc: "Sampler temperature, threaded into Request#extra (ollama honors it)"
  method_option :seed, type: :numeric,
                       desc: "Sampler seed, threaded into Request#extra (ollama honors it)"
  method_option :journal, type: :boolean, default: true,
                          desc: "Write a durable, replayable session journal (fsync'd); --no-journal opts out"
  method_option :resume, type: :string, banner: "[SESSION]", lazy_default: "",
                         desc: "Resume a recorded session: bare --resume picks the newest; or a " \
                               "filename/prefix under this project's session dir"
  method_option :fork, type: :string, banner: "SESSION@DIGEST",
                       desc: "Fork a recorded session at <session>@<digest-prefix>; the parent is opened read-only"
  method_option :btw, type: :boolean, default: false,
                      desc: "Ephemeral session (<ts>-<pid>.btw.ndjson), reaped on clean exit unless promoted"
  method_option :nvim, type: :string,
                       desc: "Attach a Neovim frontend to this --listen socket (live lain:// views)"
  method_option :grace, type: :numeric, default: Lain::CLI::Shutdown::GRACE_DEFAULT,
                        desc: "Grace seconds a first Ctrl-C / SIGTERM grants a run before it is stopped"
  default_task :chat

  # The lifecycle bracket (resolve --resume, open the journal, run the
  # conversation, always close -- refusal-before-journal ordering included)
  # lives in Lain::CLI::ChatLaunch, where it carries specs; this method stays
  # the flag-parse + error-mapping shell, `say` the one output seam lent in.
  def chat
    Lain::CLI::ChatLaunch.new(options).call { |notice| say notice }
  rescue Lain::Error => e
    raise Thor::Error, e.message
  end

  desc "sessions", "List this project's recorded sessions (newest first)"
  method_option :all, type: :boolean, default: false, desc: "Include ephemeral (--btw) sessions"
  def sessions = render { Lain::CLI::Sessions.new.listing(all: options[:all]) }

  desc "watch SELECTOR", "Read-only live tail of one actor's lineage (SELECTOR = spawn digest prefix)"
  method_option :session, type: :string, desc: "Session file to tail; defaults to this project's newest"
  def watch(selector)
    exit Lain::CLI::Watch.new(selector:, path: options[:session], sink: $stdout).run
  rescue Interrupt
    # Ctrl-C is how a tail of a SIGKILL'd (never-closed) session ends -- a
    # clean exit, not a backtrace.
    exit 0
  rescue Lain::Error => e
    raise Thor::Error, e.message
  end

  desc "friction SESSION", "Knob guidance from a session's friction signals (offline, deterministic)"
  def friction(selector) = render { Lain::CLI::Friction.new.report_for(selector) }

  desc "improvements", "Cross-project dogfood notes accumulated via the improvement_write tool"
  method_option :project, type: :string,
                          desc: "Filter to one project: a 12-hex-char hash, or a path resolved the same way"
  method_option :kind, type: :string, desc: "Filter to one kind: knob, bug, missing-feature, or doc"
  def improvements = render { Lain::CLI::Improvements.new.report(project: options[:project], kind: options[:kind]) }

  desc "consolidate SESSION", "Court-clerk pass: distill a session's completed subagent lineages into memory"
  method_option :dry_run, type: :boolean, default: false, desc: "Report what would be clerked, no spawn, no API key"
  method_option :provider, type: :string, default: "anthropic", desc: "Model provider: anthropic, ollama, or bedrock"
  method_option :model, type: :string, desc: "Model id; the provider's own default when unset"
  method_option :max_tokens, type: :numeric, default: 4_096, desc: "max_tokens per clerk turn"
  def consolidate(selector) = render { Lain::CLI::Consolidate.from_options(options).report_for(selector, dry_run: options[:dry_run]) }

  desc "improve SESSION", "Harness-improver pass: record what would make lain itself better, into the dogfood queue"
  method_option :dry_run, type: :boolean, default: false, desc: "Report what would spawn, no provider, no API key"
  method_option :provider, type: :string, default: "anthropic", desc: "Model provider: anthropic, ollama, or bedrock"
  method_option :model, type: :string, desc: "Model id; the provider's own default when unset"
  method_option :max_tokens, type: :numeric, default: 4_096, desc: "max_tokens per improver turn"
  def improve(selector) = render { Lain::CLI::Improve.from_options(options).report_for(selector, dry_run: options[:dry_run]) }

  desc "up [-- CHAT_FLAGS...]", "Create/attach the lain tmux session (chat window + status HUD)"
  method_option :session, type: :string, default: Lain::CLI::Up::DEFAULT_SESSION, desc: "tmux session name"
  method_option :socket, type: :string, desc: "tmux socket (-L); default tmux socket when unset"
  def up(*chat_args)
    # ENV.key?("TMUX") is THIS shell's own answer to "am I already an
    # attached tmux client" -- Up#attach_command turns that into the right
    # verb (switch-client vs. attach); see its doc comment for why the
    # branch has to happen before exec, and the cross-server known gap.
    plan = Lain::CLI::Up.new(session: options[:session], socket: options[:socket],
                             chat_args: chat_flags!(chat_args))
                        .launch_plan(nested: ENV.key?("TMUX"))
    plan.messages.each { |line| say(line) }
    # exec REPLACES this process, so nothing after this line ever runs --
    # flush stdout first: `say`'s writes above are not guaranteed flushed
    # yet when stdout isn't a TTY (no at_exit/implicit flush fires once
    # exec has taken over).
    $stdout.flush
    Kernel.exec(*plan.argv)
  rescue Lain::Error => e
    raise Thor::Error, e.message
  end

  private

  # `up` forwards trailing args to the chat window ONLY when the invocation
  # carried a `--` separator (see .start); a bare `lain up typo` stays a loud
  # error, never silent pass-through to chat.
  def chat_flags!(chat_args)
    return chat_args if chat_args.empty? || self.class.double_dash?

    raise Thor::Error, "unexpected arguments #{chat_args.inspect} -- pass chat flags after `--`"
  end

  # The one command-body shape every read-only report command shares: say the
  # String the block returns, mapping Lain::Error onto Thor's exit contract
  # (a clean message, never a raw backtrace).
  def render(&block)
    say block.call
  rescue Lain::Error => e
    raise Thor::Error, e.message
  end
end

# Guarded so a spec can `load` this file to reach the Thor class itself
# (cli_spec.rb driving LainCLI and its Backend alias -- the assembly seams now
# live in Lain::CLI::Wiring) without parsing ARGV or hitting the network. Direct execution
# compares paths; an INSTALLED gem runs through the RubyGems binstub, which
# `load`s this file with $0 still naming the wrapper -- the wrapper's basename
# is also "lain", which a spec's $0 (rspec) never is. Found by the gem-install
# smoke: the path-only guard made the installed executable a silent no-op.
LainCLI.start(ARGV) if $PROGRAM_NAME == __FILE__ || File.basename($PROGRAM_NAME) == File.basename(__FILE__)
