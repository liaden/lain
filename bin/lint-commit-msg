#!/usr/bin/env ruby
# frozen_string_literal: true

# commit-msg hook: enforce the mechanical parts of the commit-message standard
# (see memory git-commit-narrative). Subjective calls -- is a real WHY present,
# is the prose terse enough -- stay with the author. This catches only the rules
# a machine can judge without false positives, so a green run never means the
# message is good, only that it is not obviously wrong.
#
# Runs at the commit-msg stage under pre-commit and receives COMMIT_EDITMSG as
# ARGV[0]. Pure stdlib, so the hook stays fast and never loads the gem.

# Applies the mechanically checkable rules and returns human-readable
# violations, empty when the message passes.
class CommitMessageLinter
  SUBJECT_MAX = 72

  # em / en / figure dashes and the horizontal bar: never intrinsic to a word,
  # always the LLM-prose tell the standard bans. ASCII "--" is deliberately left
  # alone; it is a real argument separator in `git checkout -- path`.
  DASHES = /[‒–—―]/

  # Canonical trailers, colon-anchored so a prose sentence that merely contains
  # one of these words is not a false hit. Plus the machine-generation tells.
  TRAILER = /\A\s*(?:co-authored-by|signed-off-by|change-id|reviewed-by|acked-by|helped-by|tested-by|reported-by):/i
  GENERATED = /generated with \[?claude|\u{1F916}/i

  # Autogenerated or transient subjects we do not police.
  SKIP_SUBJECT = /\A(?:Merge |Revert "|fixup! |squash! |amend! )/

  def self.lint(raw)
    new(raw).violations
  end

  def initialize(raw)
    @lines = strip_comments(raw).lines.map(&:chomp)
    @content = @lines.index { |l| !l.strip.empty? }
    @subject = @content && @lines[@content]
  end

  def violations
    return [] if @subject.nil? || @subject.empty? # empty message is git's concern
    return [] if @subject.match?(SKIP_SUBJECT) # merges / reverts / autosquash

    [over_length, trailing_period, missing_blank_line, prose_dashes, trailer].compact
  end

  private

  def over_length
    return if @subject.length <= SUBJECT_MAX

    "subject is #{@subject.length} chars; keep it <= #{SUBJECT_MAX}"
  end

  def trailing_period
    "subject should not end with a period" if @subject.rstrip.end_with?(".")
  end

  def missing_blank_line
    return unless body_follows_subject? && !blank_after_subject?

    "leave the second line blank to separate subject from body"
  end

  def prose_dashes
    "no em/en dashes; use plain words (ASCII -- inside code is fine)" if body_text.match?(DASHES)
  end

  def trailer
    bad = @lines.find { |line| line.match?(TRAILER) || line.match?(GENERATED) }
    "drop the trailer #{bad.strip.inspect}; the standard forbids trailers" if bad
  end

  # Git strips comment lines (default '#') and everything from the
  # `# ----- >8 -----` scissors line onward before committing. Mirror that so
  # the hook lints what actually lands, not the editor scaffolding.
  def strip_comments(raw)
    before_scissors = raw.split(/^#\s*-+\s*>8\s*-+.*\n?/, 2).first || raw
    before_scissors.lines.reject { |line| line.start_with?("#") }.join
  end

  def body_follows_subject?
    @content && @lines.length > @content + 1
  end

  def blank_after_subject?
    @lines[@content + 1].to_s.strip.empty?
  end

  def body_text
    @lines.join("\n")
  end
end

if $PROGRAM_NAME == __FILE__
  path = ARGV[0]
  abort "usage: lint-commit-msg <commit-msg-file>" if path.nil? || path.empty?

  problems = CommitMessageLinter.lint(File.read(path, encoding: "UTF-8"))
  unless problems.empty?
    warn "commit message rejected (#{problems.length} issue#{"s" if problems.length > 1}):"
    problems.each { |problem| warn "  - #{problem}" }
    warn ""
    warn "Standard: terse subject, WHY over WHAT, no LLM tells. See git-commit-narrative."
    exit 1
  end
end
