#!/usr/bin/env ruby
# frozen_string_literal: true

# Regenerates the committed variance session fixtures deterministically:
# scripted Provider::Mock runs, a fixed clock, explicit paths. Running it twice
# yields byte-identical files -- spec/lain/bench/variance_fixture_spec.rb
# asserts exactly that against the committed bytes, so if this script's output
# ever drifts, the suite says so before a commit does.

require "bundler/setup"
# The leaf alone cannot load: leaf files carry no internal requires (see
# CLAUDE.md), so the constants VarianceFixtures references resolve only
# through the lain.rb manifest.
require "lain"

dir = File.expand_path("../spec/fixtures/sessions/variance", __dir__)
Lain::Bench::VarianceFixtures.write(dir:).each { |path| puts "wrote #{path} (#{File.size(path)} bytes)" }
